{
  "private": true,
  "scripts": {
    "build": "webpack --mode=production",
    "build:watch": "webpack --mode=production --watch",
    "debug": "webpack --mode=none",
    "debug:watch": "webpack --mode=development --watch",
    "lint": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext .js --ext .jsx --ext .tsx --ext .ts . --quiet --cache",
    "fix": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext .js --ext .jsx --ext .tsx --ext .ts . --quiet --fix --cache",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:debug": "jest --forceExit --detectOpenHandles --verbose",
    "test-ci": "jest --maxWorkers=2",
    "test:ci:debug": "jest --forceExit --detectOpenHandles --maxWorkers=2",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/cli": "7.29.7",
    "@babel/core": "7.29.7",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "7.20.7",
    "@babel/plugin-proposal-optional-chaining": "7.21.0",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-react": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@babel/runtime": "7.29.7",
    "@emotion/babel-preset-css-prop": "11.12.0",
    "@mattermost/client": "11.7.0",
    "@mattermost/types": "11.7.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/babel__core": "7.20.5",
    "@types/babel__template": "7.4.4",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/react-transition-group": "4.4.12",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "babel-jest": "30.4.1",
    "babel-loader": "10.1.1",
    "babel-plugin-formatjs": "11.3.10",
    "babel-plugin-typescript-to-proptypes": "2.1.0",
    "css-loader": "7.1.4",
    "eslint": "10.4.1",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-import-resolver-webpack": "0.13.11",
    "eslint-plugin-babel": "5.3.1",
    "eslint-plugin-cypress": "6.4.1",
    "eslint-plugin-header": "3.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-mattermost": "github:mattermost/eslint-plugin-mattermost",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "file-loader": "6.2.0",
    "identity-obj-proxy": "3.0.0",
    "isomorphic-fetch": "3.0.0",
    "jest": "30.4.2",
    "jest-canvas-mock": "2.5.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "17.0.0",
    "sass": "1.100.0",
    "sass-loader": "17.0.0",
    "style-loader": "4.0.0",
    "webpack": "5.107.2",
    "typescript": "5.6.3",
    "webpack-cli": "7.0.3"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@fullcalendar/core": "6.1.20",
    "@fullcalendar/interaction": "6.1.20",
    "@fullcalendar/moment-timezone": "6.1.20",
    "@fullcalendar/react": "6.1.20",
    "@fullcalendar/timegrid": "6.1.20",
    "@mattermost/compass-icons": "0.1.61",
    "core-js": "3.49.0",
    "mattermost-redux": "11.7.0",
    "moment-timezone": "0.6.2",
    "react": "19.2.7",
    "react-bootstrap": "2.10.10",
    "react-dom": "19.2.7",
    "react-redux": "9.3.0",
    "react-select": "5.10.2",
    "redux": "5.0.1",
    "reselect": "5.2.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/non_npm_dependencies/"
    ],
    "clearMocks": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}"
    ],
    "coverageReporters": [
      "lcov",
      "text-summary"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^.+\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "identity-obj-proxy",
      "^.+\\.(css|less|scss)$": "identity-obj-proxy",
      "^bundle-loader\\?lazy\\!(.*)$": "$1"
    },
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "moduleDirectories": [
      "node_modules",
      "non_npm_dependencies"
    ],
    "reporters": [
      "default",
      "jest-junit"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!react-native|react-router|mattermost-webapp)"
    ],
    "setupFiles": [
      "jest-canvas-mock"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost:8065"
    }
  }
}
